@{
    ViewData["Title"] = "ProductDetail";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}

<div class="container-fluid pb-5 pt-4">
    <div class="row px-xl-5">
        <!-- Sol: Görseller -->
        @await Component.InvokeAsync("_ProductDetailImageSliderComponentPartial",new {id=ViewBag.x})

        <!-- Orta ve Sağ: Özellikler ve Buybox -->
        @await Component.InvokeAsync("_ProductDetailFeatureComponentPartial",new {id=ViewBag.x})
    </div>

    <!-- Orta Kısım: Benzer Ürünler -->
    <style>
        .related-products-wrapper h2.section-title { display: none !important; }
        .related-products-wrapper .container-fluid { padding: 0 !important; }
        .related-products-wrapper .row { flex-wrap: nowrap !important; overflow-x: auto !important; padding-bottom: 15px; scroll-behavior: smooth; }
        .related-products-wrapper .col-lg-3 { flex: 0 0 auto !important; width: auto !important; min-width: 250px; }
        
        /* Webkit scrollbar for a cleaner look */
        .related-products-wrapper .row::-webkit-scrollbar { height: 0px; } /* Hide scrollbar completely for cleaner look since we have arrows */
        
        /* Arrow Styling */
        .slider-wrapper { position: relative; }
        .slider-btn { 
            position: absolute; top: 50%; transform: translateY(-50%); z-index: 10; 
            width: 40px; height: 40px; border-radius: 50%; background: white; border: 1px solid #e2e8f0; 
            box-shadow: 0 2px 5px rgba(0,0,0,0.1); display: flex; align-items: center; justify-content: center; 
            cursor: pointer; color: #333; transition: all 0.3s; 
        }
        .slider-btn:hover { background: #f27a1a; color: white; border-color: #f27a1a; }
        .slider-btn-left { left: -15px; }
        .slider-btn-right { right: -15px; }
    </style>
    <div class="row px-xl-5 mt-5">
        <div class="col-12 slider-wrapper related-products-wrapper">
            <h4 class="font-weight-bold mb-4">Benzer Ürünler</h4>
            <div class="slider-btn slider-btn-left" onclick="scrollSlider(this, -300)"><i class="fas fa-chevron-left"></i></div>
            <div class="slider-btn slider-btn-right" onclick="scrollSlider(this, 300)"><i class="fas fa-chevron-right"></i></div>
            @await Component.InvokeAsync("_FeatureProductsDefaultComponentPartial")
        </div>
    </div>

    <!-- Orta Kısım: Birlikte Alınanlar -->
    <div class="row px-xl-5 mt-5">
        <div class="col-12 slider-wrapper related-products-wrapper">
            <h4 class="font-weight-bold mb-4">Bu Ürünü Alanlar Bunları da Aldı</h4>
            <div class="slider-btn slider-btn-left" onclick="scrollSlider(this, -300)"><i class="fas fa-chevron-left"></i></div>
            <div class="slider-btn slider-btn-right" onclick="scrollSlider(this, 300)"><i class="fas fa-chevron-right"></i></div>
            @await Component.InvokeAsync("_FeatureProductsDefaultComponentPartial")
        </div>
    </div>

    <script>
        function scrollSlider(btn, amount) {
            // Find the closest wrapper, then find the scrollable row inside it
            const wrapper = btn.closest('.slider-wrapper');
            const row = wrapper.querySelector('.row');
            if(row) {
                row.scrollBy({ left: amount, behavior: 'smooth' });
            }
        }
    </script>

    <div class="row px-xl-5 mt-5">
        <div class="col">
            <!-- Ürün Değerlendirmeleri Bölümü -->
            <div id="reviews" class="bg-white p-4 mb-4" style="border: 1px solid #e2e8f0; border-radius: 8px;">
                <h4 class="font-weight-bold mb-4 border-bottom pb-3">Ürün Değerlendirmeleri</h4>
                @await Component.InvokeAsync("_ProductDetailReviewComponentPartial",new {id=ViewBag.x})
            </div>

            <!-- Ürün Soru ve Cevapları Bölümü (Dummy) -->
            <div id="qa" class="bg-white p-4 mb-4" style="border: 1px solid #e2e8f0; border-radius: 8px;">
                <h4 class="font-weight-bold mb-4 border-bottom pb-3">Ürün Soru ve Cevapları</h4>
                <div class="p-3 mb-3" style="border: 1px solid #f1f5f9; border-radius: 8px;">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="font-weight-bold" style="font-size: 14px;">"Bu ürün orjinal mi?"</span>
                        <span class="text-muted" style="font-size: 12px;">12 Mayıs 2026</span>
                    </div>
                    <div class="bg-light p-3 mt-2 rounded" style="border-left: 3px solid #f27a1a;">
                        <strong class="d-block mb-1 text-dark" style="font-size: 13px;">ÇarşıPazar Satıcısının Cevabı:</strong>
                        <span style="font-size: 13px;">Merhaba, evet mağazamızdaki tüm ürünler orjinal ve faturalıdır. Güvenle alışveriş yapabilirsiniz.</span>
                    </div>
                </div>
            </div>

            <!-- Ürün Bilgileri ve Açıklamaları -->
            <div id="details" class="bg-white p-4 mb-4" style="border: 1px solid #e2e8f0; border-radius: 8px;">
                <h4 class="font-weight-bold mb-4 border-bottom pb-3">Ürün Bilgileri</h4>
                <div class="row">
                    <div class="col-md-12">
                        @await Component.InvokeAsync("_ProductDetailDescriptionComponentPartial",new {id=ViewBag.x})
                    </div>
                </div>
            </div>
            
        </div>
    </div>
</div>