@{
    ViewData["Title"] = "Şifre Değişikliği";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}

<div class="profile-container">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <div class="profile-sidebar shadow-sm">
                    <div class="sidebar-header">
                        <h4>Hesabım</h4>
                        <small class="text-muted">Profil</small>
                    </div>
                    
                    <div class="sidebar-section-title">Siparişlerim</div>
                    <ul class="sidebar-menu">
                        <li class="sidebar-menu-item"><a href="/User/MyOrders"><i class="fas fa-box"></i> Tüm Siparişlerim</a></li>
                        <li class="sidebar-menu-item"><a href="/User/MyReviews"><i class="fas fa-star"></i> Değerlendirmelerim</a></li>
                    </ul>

                    <div class="sidebar-section-title">Hesabım & Yardım</div>
                    <ul class="sidebar-menu">
                        <li class="sidebar-menu-item"><a href="/User/Index"><i class="fas fa-user"></i> Kullanıcı Bilgilerim</a></li>
                        <li class="sidebar-menu-item"><a href="/User/MyAddress"><i class="fas fa-map-marker-alt"></i> Adres Bilgilerim</a></li>
                        <li class="sidebar-menu-item"><a href="/User/MyCards"><i class="fas fa-credit-card"></i> Kayıtlı Kartlarım</a></li>
                        <li class="sidebar-menu-item active"><a href="/User/MyPassword"><i class="fas fa-lock"></i> Şifre Değişikliği</a></li>
                        <li class="sidebar-menu-item text-danger"><a href="/Login/LogOut"><i class="fas fa-sign-out-alt"></i> Çıkış Yap</a></li>
                    </ul>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <div class="profile-content shadow-sm">
                    <div class="content-header">
                        <h2>Şifre Değişikliği</h2>
                        <p class="text-muted">Güvenliğiniz için şifrenizi belirli aralıklarla değiştirmenizi öneririz.</p>
                    </div>

                    <div class="row mt-4">
                        <div class="col-md-8">
                            <form>
                                <div class="form-group mb-4">
                                    <label class="font-weight-bold">Mevcut Şifreniz</label>
                                    <input type="password" class="form-control p-4" placeholder="Mevcut şifrenizi giriniz">
                                </div>
                                <div class="form-group mb-4">
                                    <label class="font-weight-bold">Yeni Şifre</label>
                                    <input type="password" class="form-control p-4" placeholder="Yeni şifrenizi giriniz">
                                    <small class="form-text text-muted mt-2">Şifreniz en az 8 karakter uzunluğunda olmalı, harf ve rakam içermelidir.</small>
                                </div>
                                <div class="form-group mb-4">
                                    <label class="font-weight-bold">Yeni Şifre (Tekrar)</label>
                                    <input type="password" class="form-control p-4" placeholder="Yeni şifrenizi tekrar giriniz">
                                </div>
                                <button type="button" class="btn font-weight-bold px-5 py-3 mt-2" style="background-color: #ffd333; color: #3d464d;" onclick="showToast('Şifre değiştirme işlemi Backend API eksikliği nedeniyle şu an simüle edilmektedir.', 'info')">Şifreyi Güncelle</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
