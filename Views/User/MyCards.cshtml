@{
    ViewData["Title"] = "Kayıtlı Kartlarım";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}

<div class="profile-container">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-3">
                <div class="profile-sidebar shadow-sm">
                    <div class="sidebar-header">
                        <h4>Hesabım</h4>
                        <small class="text-muted">Profil</small>
                    </div>
                    
                    <div class="sidebar-section-title">Siparişlerim</div>
                    <ul class="sidebar-menu">
                        <li class="sidebar-menu-item"><a href="/User/MyOrders"><i class="fas fa-box"></i> Tüm Siparişlerim</a></li>
                        <li class="sidebar-menu-item"><a href="/User/MyReviews"><i class="fas fa-star"></i> Değerlendirmelerim</a></li>
                    </ul>

                    <div class="sidebar-section-title">Hesabım & Yardım</div>
                    <ul class="sidebar-menu">
                        <li class="sidebar-menu-item"><a href="/User/Index"><i class="fas fa-user"></i> Kullanıcı Bilgilerim</a></li>
                        <li class="sidebar-menu-item"><a href="/User/MyAddress"><i class="fas fa-map-marker-alt"></i> Adres Bilgilerim</a></li>
                        <li class="sidebar-menu-item active"><a href="/User/MyCards"><i class="fas fa-credit-card"></i> Kayıtlı Kartlarım</a></li>
                        <li class="sidebar-menu-item"><a href="/User/MyPassword"><i class="fas fa-lock"></i> Şifre Değişikliği</a></li>
                        <li class="sidebar-menu-item text-danger"><a href="/Login/LogOut"><i class="fas fa-sign-out-alt"></i> Çıkış Yap</a></li>
                    </ul>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-9">
                <div class="profile-content shadow-sm">
                    <div class="content-header d-flex justify-content-between align-items-center">
                        <div>
                            <h2>Kayıtlı Kartlarım</h2>
                            <p class="text-muted mb-0">Hızlı ve güvenli alışveriş için kredi/banka kartlarınızı kaydedebilirsiniz.</p>
                        </div>
                        <a href="/User/AddCard" class="btn btn-warning font-weight-bold"><i class="fas fa-plus"></i> Yeni Kart Ekle</a>
                    </div>

                    @if (Context.Request.Cookies["MockCardName"] != null)
                    {
                        var cardName = Context.Request.Cookies["MockCardName"];
                        var cardNumber = Context.Request.Cookies["MockCardNumber"];
                        var expiry = Context.Request.Cookies["MockExpiryDate"];
                        
                        <div class="row mt-4">
                            <div class="col-md-6">
                                <div class="card bg-dark text-white mb-4" style="border-radius: 15px; height: 200px; box-shadow: 0 4px 8px rgba(0,0,0,0.2);">
                                    <div class="card-body p-4 d-flex flex-column justify-content-between">
                                        <div class="d-flex justify-content-between align-items-start">
                                            <i class="fas fa-microchip fa-2x text-warning"></i>
                                            <h5 class="mb-0 text-white font-weight-bold" style="letter-spacing: 2px;">VISA</h5>
                                        </div>
                                        <div class="text-center mt-3">
                                            <h3 class="mb-0 text-white font-weight-bold" style="letter-spacing: 3px;">@cardNumber</h3>
                                        </div>
                                        <div class="d-flex justify-content-between mt-3">
                                            <div>
                                                <small class="text-white-50 d-block">Kart Sahibi</small>
                                                <span class="text-white text-uppercase">@cardName</span>
                                            </div>
                                            <div class="text-right">
                                                <small class="text-white-50 d-block">SKT</small>
                                                <span class="text-white">@expiry</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="alert alert-warning mt-4 text-center">
                            <i class="far fa-credit-card fa-3x mb-3 mt-2" style="color: #ffc107;"></i>
                            <h5>Kayıtlı kartınız bulunmamaktadır.</h5>
                            <p>Alışverişlerinizi daha hızlı tamamlamak için kart bilgilerinizi güvenle kaydedebilirsiniz.</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
