@{
    ViewData["Title"] = "Ödeme Ekranı";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}

<style>
    /* ===== GENEL ===== */
    .payment-page {
        background: #f4f6fb;
        min-height: 70vh;
        padding: 40px 0 60px;
    }

    .payment-page h2 {
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 8px;
    }

    .payment-page .subtitle {
        color: #6c757d;
        margin-bottom: 32px;
    }

    /* ===== YÖNTEM KARTLARI ===== */
    .method-grid {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-bottom: 36px;
    }

    .method-card {
        flex: 1;
        min-width: 160px;
        background: #fff;
        border: 2px solid #e0e0e0;
        border-radius: 16px;
        padding: 28px 20px;
        text-align: center;
        cursor: pointer;
        transition: all 0.25s ease;
        position: relative;
    }

    .method-card:hover {
        border-color: #7c3aed;
        box-shadow: 0 6px 24px rgba(124,58,237,0.12);
        transform: translateY(-3px);
    }

    .method-card.active {
        border-color: #7c3aed;
        background: linear-gradient(135deg, #f5f0ff 0%, #ede9fe 100%);
        box-shadow: 0 6px 24px rgba(124,58,237,0.18);
    }

    .method-card .check-badge {
        display: none;
        position: absolute;
        top: 12px;
        right: 12px;
        width: 22px;
        height: 22px;
        background: #7c3aed;
        border-radius: 50%;
        color: #fff;
        font-size: 12px;
        align-items: center;
        justify-content: center;
    }

    .method-card.active .check-badge {
        display: flex;
    }

    .method-card .method-icon {
        font-size: 38px;
        margin-bottom: 12px;
    }

    .method-card .method-title {
        font-weight: 600;
        color: #1a1a2e;
        font-size: 15px;
    }

    .method-card .method-desc {
        font-size: 12px;
        color: #888;
        margin-top: 4px;
    }

    /* ===== FORM PANELLERİ ===== */
    .payment-panel {
        display: none;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.08);
        padding: 36px 40px;
        animation: fadeIn 0.3s ease;
    }

    .payment-panel.show {
        display: block;
    }

    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .panel-title {
        font-size: 18px;
        font-weight: 700;
        color: #1a1a2e;
        margin-bottom: 24px;
        padding-bottom: 14px;
        border-bottom: 2px solid #f0f0f0;
    }

    /* ===== KREDİ KARTI ===== */
    .card-container {
        perspective: 1000px;
        width: 360px;
        height: 210px;
        margin: 0 auto 32px;
    }

    .card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        transform-style: preserve-3d;
        transition: transform 0.6s;
    }

    .card-inner.flipped {
        transform: rotateY(180deg);
    }

    .card-front, .card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        backface-visibility: hidden;
        border-radius: 18px;
        overflow: hidden;
    }

    .card-front {
        background: linear-gradient(135deg, #7c3aed 0%, #3b82f6 100%);
        padding: 24px 28px;
        color: #fff;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .card-back {
        background: linear-gradient(135deg, #3b82f6 0%, #7c3aed 100%);
        transform: rotateY(180deg);
        padding: 0;
        display: flex;
        flex-direction: column;
    }

    .card-logo { font-size: 22px; font-weight: 800; letter-spacing: 2px; }
    .card-chip { font-size: 28px; }
    .card-number-disp { font-size: 20px; letter-spacing: 4px; font-family: monospace; font-weight: 600; }
    .card-holder-disp { font-size: 13px; opacity: .8; }
    .card-name-disp { font-size: 15px; font-weight: 600; text-transform: uppercase; }
    .card-exp-disp { font-size: 13px; opacity: .8; }
    .card-exp-val { font-size: 15px; font-weight: 600; }

    .card-back .stripe { background: #1a1a1a; height: 46px; margin-top: 28px; }
    .card-back .cvv-area { padding: 12px 28px; }
    .card-back .cvv-label { font-size: 11px; color: rgba(255,255,255,.7); }
    .card-back .cvv-box { background: #fff; color: #333; letter-spacing: 6px; font-family: monospace; font-weight: 700; font-size: 16px; border-radius: 6px; padding: 6px 14px; display: inline-block; margin-top: 4px; min-width: 70px; }

    /* ===== FORM ELEMANLARİ ===== */
    .form-group label {
        font-weight: 600;
        font-size: 13px;
        color: #444;
        margin-bottom: 6px;
    }

    .form-control {
        border: 1.5px solid #e0e0e0;
        border-radius: 10px;
        padding: 10px 14px;
        font-size: 14px;
        transition: border-color 0.2s;
    }

    .form-control:focus {
        border-color: #7c3aed;
        box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
    }

    .btn-pay {
        background: linear-gradient(135deg, #7c3aed, #3b82f6);
        border: none;
        color: #fff;
        border-radius: 12px;
        padding: 14px;
        font-size: 16px;
        font-weight: 700;
        width: 100%;
        margin-top: 8px;
        transition: opacity 0.2s, transform 0.2s;
        cursor: pointer;
    }

    .btn-pay:hover { opacity: 0.93; transform: translateY(-1px); }

    /* ===== HAVALE ===== */
    .bank-card {
        border: 1.5px solid #e0e0e0;
        border-radius: 14px;
        padding: 20px 24px;
        margin-bottom: 14px;
        display: flex;
        align-items: center;
        gap: 16px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .bank-card:hover, .bank-card.selected {
        border-color: #7c3aed;
        background: #f9f5ff;
    }

    .bank-card .bank-icon { font-size: 28px; }
    .bank-card .bank-name { font-weight: 600; font-size: 15px; color: #1a1a2e; }
    .bank-card .bank-iban { font-size: 12px; color: #888; margin-top: 2px; }

    /* ===== KAPIDA ÖDEME ===== */
    .doorstep-info {
        background: linear-gradient(135deg, #f0fdf4, #dcfce7);
        border: 1.5px solid #86efac;
        border-radius: 14px;
        padding: 24px 28px;
        margin-bottom: 24px;
    }

    .doorstep-info .info-icon { font-size: 40px; margin-bottom: 10px; }
    .doorstep-info h5 { color: #166534; font-weight: 700; }
    .doorstep-info p { color: #15803d; margin: 0; font-size: 14px; }

    .doorstep-fee {
        background: #fff7ed;
        border: 1.5px solid #fed7aa;
        border-radius: 10px;
        padding: 14px 20px;
        margin-bottom: 20px;
        font-size: 14px;
        color: #c2410c;
        font-weight: 500;
    }

    /* ===== VALIDATION ===== */
    .form-control.is-invalid {
        border-color: #dc3545 !important;
        box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.15) !important;
    }
    .invalid-feedback {
        color: #dc3545 !important;
        display: block;
        font-size: 12px;
        font-weight: 500;
        margin-top: 5px;
        text-align: left;
    }
</style>

<div class="payment-page">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <h2 class="text-center">💳 Ödeme Ekranı</h2>
                <p class="subtitle text-center">Aşağıdan ödeme yönteminizi seçin</p>

                <!-- YÖNTEM SEÇİM KARTLARI -->
                <div class="method-grid">

                    <div class="method-card" id="btn-card" onclick="selectMethod('card')">
                        <div class="check-badge">✓</div>
                        <div class="method-icon">💳</div>
                        <div class="method-title">Kredi / Banka Kartı</div>
                        <div class="method-desc">Visa, Mastercard, Troy</div>
                    </div>

                    <div class="method-card" id="btn-transfer" onclick="selectMethod('transfer')">
                        <div class="check-badge">✓</div>
                        <div class="method-icon">🏦</div>
                        <div class="method-title">Havale / EFT</div>
                        <div class="method-desc">Banka transferi ile öde</div>
                    </div>

                    <div class="method-card" id="btn-door" onclick="selectMethod('door')">
                        <div class="check-badge">✓</div>
                        <div class="method-icon">🚪</div>
                        <div class="method-title">Kapıda Ödeme</div>
                        <div class="method-desc">Nakit veya kartla kapıda</div>
                    </div>

                </div>

                <!-- PANEL: KREDİ KARTI -->
                <div class="payment-panel" id="panel-card">
                    <div class="panel-title">💳 Kart Bilgilerinizi Girin</div>

                    <!-- Animasyonlu Kart -->
                    <div class="card-container">
                        <div class="card-inner" id="cardInner">
                            <div class="card-front">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div class="card-logo">ÇARŞIPAZAR</div>
                                    <div class="card-chip">📲</div>
                                </div>
                                <div class="card-number-disp" id="dispNumber">#### #### #### ####</div>
                                <div class="d-flex justify-content-between align-items-flex-end">
                                    <div>
                                        <div class="card-holder-disp">Kart Sahibi</div>
                                        <div class="card-name-disp" id="dispName">AD SOYAD</div>
                                    </div>
                                    <div>
                                        <div class="card-exp-disp">Son Tarih</div>
                                        <div class="card-exp-val" id="dispExp">MM/YY</div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-back">
                                <div class="stripe"></div>
                                <div class="cvv-area">
                                    <div class="cvv-label">CVV</div>
                                    <div class="cvv-box" id="dispCvv">***</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Kart Formu -->
                    <form>
                        <div class="form-group mb-3">
                            <label>Kart Numarası</label>
                            <input type="text" id="inpNumber" class="form-control" placeholder="0000 0000 0000 0000" maxlength="19" oninput="formatCardNumber(this)">
                        </div>
                        <div class="form-group mb-3">
                            <label>Kart Üzerindeki Ad Soyad</label>
                            <input type="text" id="inpName" class="form-control" placeholder="Ad Soyad" oninput="document.getElementById('dispName').innerText = this.value.toUpperCase() || 'AD SOYAD'">
                        </div>
                        <div class="row">
                            <div class="col-6">
                                <div class="form-group mb-3">
                                    <label>Son Kullanma (AA/YY)</label>
                                    <input type="text" id="inpExp" class="form-control" placeholder="MM/YY" maxlength="5" oninput="formatExp(this)">
                                </div>
                            </div>
                            <div class="col-6">
                                <div class="form-group mb-3">
                                    <label>CVV</label>
                                    <input type="text" id="inpCvv" class="form-control" placeholder="***" maxlength="3"
                                        onfocus="document.getElementById('cardInner').classList.add('flipped')"
                                        onblur="document.getElementById('cardInner').classList.remove('flipped')"
                                        oninput="document.getElementById('dispCvv').innerText = this.value || '***'">
                                </div>
                            </div>
                        </div>
                        <button type="button" class="btn-pay" onclick="completePayment()">✅ Ödemeyi Tamamla</button>
                    </form>
                </div>

                <!-- PANEL: HAVALE/EFT -->
                <div class="payment-panel" id="panel-transfer">
                    <div class="panel-title">🏦 Havale / EFT ile Ödeme</div>
                    <p class="text-muted mb-4" style="font-size:14px;">Aşağıdaki banka hesaplarından birine sipariş tutarını (₺<span id="transferAmount">0</span>) gönderin. Açıklamaya sipariş numaranızı yazmayı unutmayın.</p>

                    <div class="bank-card" onclick="selectBank(this)">
                        <div class="bank-icon">🟣</div>
                        <div>
                            <div class="bank-name">Akbank</div>
                            <div class="bank-iban">IBAN: TR12 0000 1234 5678 9012 34</div>
                        </div>
                    </div>

                    <div class="bank-card" onclick="selectBank(this)">
                        <div class="bank-icon">🔵</div>
                        <div>
                            <div class="bank-name">Garanti BBVA</div>
                            <div class="bank-iban">IBAN: TR34 0006 2000 1140 0006 2991 26</div>
                        </div>
                    </div>

                    <div class="bank-card" onclick="selectBank(this)">
                        <div class="bank-icon">🟢</div>
                        <div>
                            <div class="bank-name">Ziraat Bankası</div>
                            <div class="bank-iban">IBAN: TR56 0001 0017 4538 7360 3950 01</div>
                        </div>
                    </div>

                    <button type="button" class="btn-pay mt-2" onclick="completePayment()">✅ Ödemeyi Tamamla</button>
                </div>

                <!-- PANEL: KAPIDA ÖDEME -->
                <div class="payment-panel" id="panel-door">
                    <div class="panel-title">🚪 Kapıda Ödeme</div>

                    <div class="doorstep-info text-center">
                        <div class="info-icon">✅</div>
                        <h5>Kapıda Ödeme Seçildi</h5>
                        <p>Siparişiniz kapınıza geldiğinde nakit veya pos cihazıyla ödeme yapabilirsiniz.</p>
                    </div>

                    <div class="doorstep-fee">
                        ⚠️ Kapıda ödeme için <strong>+15 ₺</strong> hizmet bedeli alınmaktadır.
                    </div>

                    <div class="form-group mb-3">
                        <label>Teslimat Notu (İsteğe Bağlı)</label>
                        <textarea class="form-control" rows="3" placeholder="Kapıcıya bırakın, zil çalmayın vb."></textarea>
                    </div>

                    <button type="button" class="btn-pay" onclick="completePayment()">✅ Siparişi Onayla</button>
                </div>

            </div>
        </div>
    </div>
</div>

<!-- Başarı Modal -->
<div class="modal fade" id="successModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:20px; text-align:center; padding: 32px;">
            <div style="font-size:56px; margin-bottom:12px;">🎉</div>
            <h4 style="font-weight:700; color:#1a1a2e;">Siparişiniz Alındı!</h4>
            <p style="color:#666;">Ödemeniz başarıyla işlendi. Sipariş detaylarınız e-posta adresinize gönderildi.</p>
            <a href="/" class="btn-pay" style="display:inline-block; text-decoration:none; padding: 12px 28px; margin-top:8px;">🏠 Ana Sayfaya Dön</a>
        </div>
    </div>
</div>

<script>
    function selectMethod(method) {
        // Kartları güncelle
        document.querySelectorAll('.method-card').forEach(c => c.classList.remove('active'));
        document.getElementById('btn-' + method).classList.add('active');

        // Panelleri gizle
        document.querySelectorAll('.payment-panel').forEach(p => p.classList.remove('show'));

        // İlgili paneli göster
        document.getElementById('panel-' + method).classList.add('show');

        // Smooth scroll
        document.getElementById('panel-' + method).scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function formatCardNumber(input) {
        let v = input.value.replace(/\D/g, '').substring(0, 16);
        let formatted = v.replace(/(.{4})/g, '$1 ').trim();
        input.value = formatted;
        // Ekrandaki kartı güncelle
        document.getElementById('dispNumber').innerText = formatted.padEnd(19, '#').replace(/#/g, '#').substring(0, 19) || '#### #### #### ####';
        let display = v.padEnd(16, '#');
        document.getElementById('dispNumber').innerText =
            display.substring(0,4) + ' ' + display.substring(4,8) + ' ' + display.substring(8,12) + ' ' + display.substring(12,16);
    }

    function formatExp(input) {
        let v = input.value.replace(/\D/g, '').substring(0, 4);
        if (v.length >= 3) v = v.substring(0, 2) + '/' + v.substring(2);
        input.value = v;
        document.getElementById('dispExp').innerText = v || 'MM/YY';
    }

    function selectBank(el) {
        // Remove previous alert if any
        let bankAlert = document.getElementById('bank-alert');
        if (bankAlert) bankAlert.remove();

        document.querySelectorAll('.bank-card').forEach(c => c.classList.remove('selected'));
        el.classList.add('selected');
    }

    function completePayment() {
        // Clear all previous errors
        document.querySelectorAll('.form-control').forEach(el => {
            el.classList.remove('is-invalid');
            let feedback = el.parentNode.querySelector('.invalid-feedback');
            if (feedback) feedback.remove();
        });
        
        let bankAlert = document.getElementById('bank-alert');
        if (bankAlert) bankAlert.remove();

        // Get currently active payment method
        let activeCard = document.querySelector('.method-card.active');
        let selectedPaymentMethod = activeCard ? activeCard.id.replace('btn-', '') : 'card';

        if (selectedPaymentMethod === 'card') {
            let isValid = true;

            // 1. Kart Numarası Validation
            let inpNumber = document.getElementById('inpNumber');
            let cardNum = inpNumber.value.replace(/\D/g, '');
            if (cardNum.length !== 16) {
                showError(inpNumber, 'Lütfen 16 haneli geçerli bir kart numarası giriniz.');
                isValid = false;
            }

            // 2. Ad Soyad Validation
            let inpName = document.getElementById('inpName');
            if (inpName.value.trim().length < 5) {
                showError(inpName, 'Lütfen kart üzerindeki adı soyadı giriniz (en az 5 karakter).');
                isValid = false;
            }

            // 3. Son Kullanma Validation
            let inpExp = document.getElementById('inpExp');
            let expRegex = /^(0[1-9]|1[0-2])\/([0-9]{2})$/;
            if (!expRegex.test(inpExp.value.trim())) {
                showError(inpExp, 'Geçerli bir tarih giriniz (AA/YY).');
                isValid = false;
            } else {
                let parts = inpExp.value.split('/');
                let expMonth = parseInt(parts[0], 10);
                let expYear = parseInt('20' + parts[1], 10);
                let now = new Date();
                let currentMonth = now.getMonth() + 1;
                let currentYear = now.getFullYear();
                if (expYear < currentYear || (expYear === currentYear && expMonth < currentMonth)) {
                    showError(inpExp, 'Kartınızın son kullanma tarihi geçmiş.');
                    isValid = false;
                }
            }

            // 4. CVV Validation
            let inpCvv = document.getElementById('inpCvv');
            let cvv = inpCvv.value.replace(/\D/g, '');
            if (cvv.length !== 3) {
                showError(inpCvv, 'Lütfen 3 haneli güvenlik kodunu (CVV) giriniz.');
                isValid = false;
            }

            if (!isValid) return;
        } 
        else if (selectedPaymentMethod === 'transfer') {
            // Check if any bank is selected
            let selectedBank = document.querySelector('.bank-card.selected');
            if (!selectedBank) {
                let transferPanel = document.getElementById('panel-transfer');
                let alertDiv = document.createElement('div');
                alertDiv.id = 'bank-alert';
                alertDiv.className = 'alert alert-danger mt-3';
                alertDiv.style.borderRadius = '12px';
                alertDiv.style.fontSize = '14px';
                alertDiv.style.fontWeight = '500';
                alertDiv.innerHTML = '⚠️ Lütfen transfer yapacağınız banka hesabını seçiniz.';
                
                // Insert above the button
                let payBtn = transferPanel.querySelector('.btn-pay');
                transferPanel.insertBefore(alertDiv, payBtn);
                return;
            }
        }

        // Show success modal if validation succeeds
        var modal = new bootstrap.Modal(document.getElementById('successModal'));
        modal.show();
    }

    function showError(inputEl, message) {
        inputEl.classList.add('is-invalid');
        let errorDiv = document.createElement('div');
        errorDiv.className = 'invalid-feedback';
        errorDiv.innerText = '⚠️ ' + message;
        inputEl.parentNode.appendChild(errorDiv);
    }

    // Set default open panel to card
    document.addEventListener("DOMContentLoaded", function() {
        selectMethod('card');
    });
</script>
