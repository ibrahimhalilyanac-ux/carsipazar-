@model GetByIdProductDetailDto
<div>
    <h5 class="mb-4 font-weight-bold" style="color: #4f46e5;">📋 Ek Bilgiler</h5>
    <p style="font-size: 13px; line-height: 1.6; color: #475569;" class="mb-4">@Model.ProductInfo</p>
    
    <div class="bg-white p-3 rounded border" style="border-color: #e2e8f0;">
        <h6 class="font-weight-bold mb-3" style="font-size: 14px;">Taksit Seçenekleri</h6>
        <div class="d-flex justify-content-between border-bottom pb-2 mb-2" style="font-size: 13px;">
            <span>Tek Çekim</span>
            <span class="font-weight-bold">Vade Farksız</span>
        </div>
        <div class="d-flex justify-content-between border-bottom pb-2 mb-2" style="font-size: 13px;">
            <span>3 Taksit</span>
            <span class="font-weight-bold">%2 Faiz Oranı ile</span>
        </div>
        <div class="d-flex justify-content-between pb-1" style="font-size: 13px;">
            <span>6 Taksit</span>
            <span class="font-weight-bold">%4 Faiz Oranı ile</span>
        </div>
    </div>
</div>