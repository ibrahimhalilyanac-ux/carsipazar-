@model GetByIdProductImageDto

<div class="col-lg-5 mb-30">
    <div id="product-carousel" class="carousel slide" data-ride="carousel" data-interval="false">
        <div class="carousel-inner bg-light" style="border-radius: 8px; border: 1px solid #e2e8f0;">
            <div class="carousel-item active">
                <img referrerpolicy="no-referrer" class="w-100" style="object-fit: contain; aspect-ratio: 3/4;" src="@Model.Image1" alt="Image">
            </div>
            <div class="carousel-item">
                <img referrerpolicy="no-referrer" class="w-100" style="object-fit: contain; aspect-ratio: 3/4;" src="@Model.Image2" alt="Image">
            </div>
            <div class="carousel-item">
                <img referrerpolicy="no-referrer" class="w-100" style="object-fit: contain; aspect-ratio: 3/4;" src="@Model.Image3" alt="Image">
            </div>
            <div class="carousel-item">
                <img referrerpolicy="no-referrer" class="w-100" style="object-fit: contain; aspect-ratio: 3/4;" src="@Model.Image4" alt="Image">
            </div>
        </div>
        <a class="carousel-control-prev" href="#product-carousel" data-slide="prev" style="width: 10%;">
            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow" style="width: 35px; height: 35px;">
                <i class="fa fa-angle-left text-dark"></i>
            </div>
        </a>
        <a class="carousel-control-next" href="#product-carousel" data-slide="next" style="width: 10%;">
            <div class="bg-white rounded-circle d-flex align-items-center justify-content-center shadow" style="width: 35px; height: 35px;">
                <i class="fa fa-angle-right text-dark"></i>
            </div>
        </a>
    </div>

    <!-- Thumbnails -->
    <div class="d-flex justify-content-center mt-3 gap-2" style="gap: 10px;">
        <div style="cursor: pointer; border: 2px solid #f27a1a; border-radius: 4px; padding: 2px;" onclick="$('#product-carousel').carousel(0)">
            <img src="@Model.Image1" style="width: 60px; height: 80px; object-fit: contain; border-radius: 2px;">
        </div>
        <div style="cursor: pointer; border: 1px solid #e2e8f0; border-radius: 4px; padding: 2px;" onclick="$('#product-carousel').carousel(1)">
            <img src="@Model.Image2" style="width: 60px; height: 80px; object-fit: contain; border-radius: 2px;">
        </div>
        <div style="cursor: pointer; border: 1px solid #e2e8f0; border-radius: 4px; padding: 2px;" onclick="$('#product-carousel').carousel(2)">
            <img src="@Model.Image3" style="width: 60px; height: 80px; object-fit: contain; border-radius: 2px;">
        </div>
        <div style="cursor: pointer; border: 1px solid #e2e8f0; border-radius: 4px; padding: 2px;" onclick="$('#product-carousel').carousel(3)">
            <img src="@Model.Image4" style="width: 60px; height: 80px; object-fit: contain; border-radius: 2px;">
        </div>
    </div>
</div>
