</style>

<div id="mini-cart-overlay" onclick="closeMiniCart()"></div>
<div id="mini-cart-sidebar">
    <div class="mini-cart-header">
        <h5 class="mb-0" id="mini-cart-title">Sepetim (0 Ürün)</h5>
        <button type="button" class="close" onclick="closeMiniCart()">&times;</button>
    </div>
    <div class="mini-cart-body" id="mini-cart-items">
        <!-- items will be injected here -->
    </div>
    <div class="mini-cart-footer">
        <div class="d-flex justify-content-between mb-3">
            <h5 class="mb-0">Ara Toplam:</h5>
            <h5 class="mb-0 text-primary" id="mini-cart-total">0 TL</h5>
        </div>
        <a href="/ShoppingCart/Index" class="btn btn-primary btn-block py-2">Sepete Git</a>
    </div>
</div>