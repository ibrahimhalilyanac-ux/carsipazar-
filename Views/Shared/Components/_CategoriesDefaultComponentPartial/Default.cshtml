@model List<ResultCategoryDto>

<div class="container-fluid pt-5">
    <h2 class="section-title position-relative text-uppercase mx-xl-5 mb-4"><span class="bg-secondary pr-3">Öne Çıkan Kategoriler</span></h2>
    <div class="row px-xl-5 pb-3">
        @{ 
            int catCount = 0;
            string[] fallbackImages = { "clothes.png", "laptop.png", "shoes.png", "phone.png", "electronics.jpg", "furniture.jpg" };
        }
        @foreach(var item in Model)
        {          
            var fallbackImage = $"/images/categoryimages/{fallbackImages[catCount % fallbackImages.Length]}";
            catCount++;
            var currentImage = string.IsNullOrEmpty(item.ImageUrl) ? fallbackImage : item.ImageUrl;
       <div class="col-lg-3 col-md-4 col-sm-6 pb-1">
            <a class="text-decoration-none" href="/ProductList/Index/@item.CategoryID">
                <div class="cat-item d-flex align-items-center mb-4">
                    <div class="overflow-hidden" style="width: 100px; height: 100px;">
                        <img referrerpolicy="no-referrer" class="img-fluid" src="@currentImage" alt="">
                    </div>
                    <div class="flex-fill pl-3">
                        <h6>@item.CategoryName</h6>
                        @{
                            var productCounts = ViewBag.ProductCounts as Dictionary<string, int>;
                            int count = productCounts != null && productCounts.ContainsKey(item.CategoryID) ? productCounts[item.CategoryID] : 0;
                        }
                        <small class="text-body">@count Ürün</small>
                    </div>
                </div>
            </a>
        </div>
        }
    </div>
</div>
