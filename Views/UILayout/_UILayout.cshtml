
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">

@await Component.InvokeAsync("_HeadUILayoutComponentPartial")

<body>

    @await Component.InvokeAsync("_TopbarUILayoutComponentPartial")

    @await Component.InvokeAsync("_NavbarUILayoutComponentPartial")


    @RenderBody()

    @await Component.InvokeAsync("_FooterUILayoutComponentPartial")

    @await Component.InvokeAsync("_ScriptUILayoutComponentPartial")

    <!-- Yapay Zeka Sohbet Butonu ve Penceresi -->
    <div id="ai-chat-container" style="position: fixed; bottom: 100px; right: 30px; z-index: 99999; font-family: 'Inter', sans-serif;">
        <!-- Yüzen Daire Buton -->
        <button id="ai-chat-btn" style="width: 60px; height: 60px; border-radius: 50%; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); border: none; color: white; font-size: 26px; cursor: pointer; box-shadow: 0 8px 24px rgba(79, 70, 229, 0.4); display: flex; align-items: center; justify-content: center; transition: all 0.3s ease; outline: none;">
            🤖
        </button>

        <!-- Sohbet Penceresi -->
        <div id="ai-chat-box" style="width: 360px; height: 500px; background: white; border-radius: 20px; box-shadow: 0 12px 40px rgba(0,0,0,0.15); display: none; flex-direction: column; overflow: hidden; border: 1px solid #e2e8f0; transition: all 0.3s ease;">
            <!-- Header -->
            <div style="background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: white; padding: 20px; display: flex; align-items: center; justify-content: space-between;">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <span style="font-size: 24px;">🤖</span>
                    <div style="text-align: left;">
                        <h6 style="margin: 0; font-weight: 800; font-size: 15px; color: white;">ÇarşıPazar Asistanı</h6>
                        <span style="font-size: 11px; opacity: 0.9; color: rgba(255,255,255,0.85);">Çevrimiçi Yapay Zeka</span>
                    </div>
                </div>
                <button id="ai-close-btn" style="background: none; border: none; color: white; font-size: 24px; cursor: pointer; opacity: 0.8; outline: none; line-height: 1;">&times;</button>
            </div>

            <!-- Mesajlaşma Alanı -->
            <div id="ai-chat-messages" style="flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 15px; background-color: #f8fafc; text-align: left;">
                <!-- Karşılama Mesajı -->
                <div style="align-self: flex-start; background: white; color: #334155; padding: 12px 16px; border-radius: 16px 16px 16px 0; max-width: 80%; font-size: 13.5px; box-shadow: 0 2px 8px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; line-height: 1.5;">
                    Merhaba! Ben ÇarşıPazar Yapay Zeka Asistanıyım. Size nasıl yardımcı olabilirim? 🛍️
                </div>
            </div>

            <!-- Mesaj Gönderme Giriş Alanı -->
            <div style="padding: 15px; background: white; border-top: 1px solid #f1f5f9; display: flex; gap: 10px; align-items: center;">
                <input type="text" id="ai-chat-input" placeholder="Sorunuzu buraya yazın..." style="flex: 1; border: 1px solid #e2e8f0; padding: 10px 15px; border-radius: 20px; font-size: 13px; outline: none; transition: border-color 0.2s;">
                <button id="ai-send-btn" style="background: #4f46e5; border: none; color: white; width: 38px; height: 38px; border-radius: 50%; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 16px; outline: none; transition: background 0.2s;">
                    ➔
                </button>
            </div>
        </div>
    </div>

    <script>var isUserAuthenticated = @(User.Identity.IsAuthenticated ? "true" : "false");</script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const chatBtn = document.getElementById('ai-chat-btn');
            const chatBox = document.getElementById('ai-chat-box');
            const closeBtn = document.getElementById('ai-close-btn');
            const sendBtn = document.getElementById('ai-send-btn');
            const chatInput = document.getElementById('ai-chat-input');
            const chatMessages = document.getElementById('ai-chat-messages');

            // Pencereyi Aç/Kapat
            chatBtn.addEventListener('click', () => {
                chatBtn.style.display = 'none';
                chatBox.style.display = 'flex';
                chatInput.focus();
            });

            closeBtn.addEventListener('click', () => {
                chatBox.style.display = 'none';
                chatBtn.style.display = 'flex';
            });

            // Mesaj Gönderme Fonksiyonu
            async function sendMessage() {
                const text = chatInput.value.trim();
                if (!text) return;

                // Kullanıcı Mesajını Ekrana Yaz
                appendMessage(text, 'user');
                chatInput.value = '';

                // Yükleniyor Mesajı
                const loadingId = appendMessage('Düşünüyor...', 'ai', true);

                try {
                    const response = await fetch('/Chat/SendMessage', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: text })
                    });

                    const data = await response.json();
                    const loadingElement = document.getElementById(loadingId);
                    if (loadingElement) loadingElement.remove(); // Yükleniyor'u kaldır
                    
                    appendMessage(data.reply, 'ai');
                } catch (error) {
                    const loadingElement = document.getElementById(loadingId);
                    if (loadingElement) {
                        loadingElement.innerText = "Üzgünüm, şu anda yanıt veremiyorum. ⚠️";
                        loadingElement.style.color = "#ef4444";
                    }
                }
            }

            function appendMessage(text, sender, isLoading = false) {
                const msgDiv = document.createElement('div');
                const id = 'msg-' + Date.now() + Math.random().toString(36).substr(2, 5);
                msgDiv.id = id;
                
                if (sender === 'user') {
                    msgDiv.style.cssText = "align-self: flex-end; background: #4f46e5; color: white; padding: 12px 16px; border-radius: 16px 16px 0 16px; max-width: 80%; font-size: 13.5px; box-shadow: 0 4px 12px rgba(79,70,229,0.15); line-height: 1.5; margin-bottom: 5px;";
                } else {
                    msgDiv.style.cssText = "align-self: flex-start; background: white; color: #334155; padding: 12px 16px; border-radius: 16px 16px 16px 0; max-width: 80%; font-size: 13.5px; box-shadow: 0 2px 8px rgba(0,0,0,0.03); border: 1px solid #f1f5f9; line-height: 1.5; margin-bottom: 5px;";
                    if (isLoading) {
                        msgDiv.style.fontStyle = "italic";
                        msgDiv.style.color = "#94a3b8";
                    }
                }

                msgDiv.innerText = text;
                chatMessages.appendChild(msgDiv);
                chatMessages.scrollTop = chatMessages.scrollHeight;
                return id;
            }

            sendBtn.addEventListener('click', sendMessage);
            chatInput.addEventListener('keypress', (e) => { if (e.key === 'Enter') sendMessage(); });
            
            // Hover effect on send button
            sendBtn.addEventListener('mouseenter', () => { sendBtn.style.backgroundColor = '#3730a3'; });
            sendBtn.addEventListener('mouseleave', () => { sendBtn.style.backgroundColor = '#4f46e5'; });
            
            // Hover effect on chat toggle button
            chatBtn.addEventListener('mouseenter', () => { chatBtn.style.transform = 'scale(1.05)'; });
            chatBtn.addEventListener('mouseleave', () => { chatBtn.style.transform = 'scale(1)'; });
        });
    </script>

 </body>
</html>