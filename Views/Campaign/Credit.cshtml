@{
    ViewData["Title"] = "Alışveriş Kredisi";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-light mb-30 shadow-sm" style="border-radius: 12px; padding: 12px 24px;">
                <a class="breadcrumb-item text-dark" href="/">Ana Sayfa</a>
                <span class="breadcrumb-item active text-primary">Alışveriş Kredisi</span>
            </nav>
        </div>
    </div>
</div>

<style>
    .credit-hero {
        background: linear-gradient(135deg, #1e3a8a 0%, #3b82f6 100%);
        border-radius: 24px;
        padding: 60px 40px;
        color: #fff;
        margin-bottom: 40px;
        box-shadow: 0 10px 30px rgba(30, 58, 138, 0.15);
        position: relative;
        overflow: hidden;
    }
    .credit-hero::before {
        content: '';
        position: absolute;
        width: 300px;
        height: 300px;
        background: rgba(255, 255, 255, 0.08);
        border-radius: 50%;
        top: -100px;
        right: -100px;
    }
    .credit-hero h1 {
        font-weight: 800;
        font-size: 42px;
        margin-bottom: 16px;
    }
    .credit-hero p {
        font-size: 18px;
        opacity: 0.9;
        max-width: 600px;
        margin: 0;
        line-height: 1.6;
    }
    .step-box {
        background: #fff;
        border-radius: 20px;
        border: 1px solid #f0f0f0;
        padding: 30px;
        text-align: center;
        height: 100%;
        box-shadow: 0 8px 32px rgba(0,0,0,0.04);
        transition: transform 0.3s;
    }
    .step-box:hover {
        transform: translateY(-5px);
    }
    .step-num {
        width: 50px;
        height: 50px;
        background: #eff6ff;
        color: #3b82f6;
        font-weight: 800;
        font-size: 20px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 20px;
    }
    .step-title {
        font-weight: 800;
        font-size: 17px;
        color: #1e293b;
        margin-bottom: 10px;
    }
    .step-desc {
        font-size: 14px;
        color: #64748b;
        line-height: 1.6;
    }
    .calc-card {
        background: #fff;
        border-radius: 24px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.04);
        border: 1px solid #e2e8f0;
        padding: 40px;
    }
</style>

<div class="container-fluid px-xl-5">
    <div class="credit-hero">
        <div class="row align-items-center">
            <div class="col-md-8">
                <h1>Kart Limitine Takılmadan Alışveriş</h1>
                <p>ÇarşıPazar Alışveriş Kredisi ile beğendiğiniz ürünleri şimdi satın alın, anlaşmalı bankalar aracılığıyla 36 aya varan taksit seçenekleriyle kolayca ödeyin.</p>
            </div>
            <div class="col-md-4 text-center d-none d-md-block">
                <span style="font-size: 110px; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.1));">💳</span>
            </div>
        </div>
    </div>

    <div class="text-center mb-5">
        <h2 style="font-weight: 800; color: #1e293b;">Alışveriş Kredisi Nasıl Çalışır?</h2>
        <p style="color: #64748b;">Sadece 3 kolay adımda kart limitinizi doldurmadan alışverişinizi tamamlayın.</p>
    </div>

    <div class="row mb-5">
        <div class="col-md-4 mb-4">
            <div class="step-box">
                <div class="step-num">1</div>
                <div class="step-title">Sepetini Oluştur</div>
                <div class="step-desc">Satın almak istediğin ürünleri sepetine ekle ve ödeme adımına ilerle.</div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="step-box">
                <div class="step-num">2</div>
                <div class="step-title">Ödeme Yöntemini Seç</div>
                <div class="step-desc">Ödeme seçenekleri arasından "Alışveriş Kredisi"ni işaretle ve dilediğin bankayı seç.</div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="step-box">
                <div class="step-num">3</div>
                <div class="step-title">Anında Onayla & Öde</div>
                <div class="step-desc">Banka ekranlarına yönlendirilerek dakikalar içinde kredini onayla ve siparişini tamamla.</div>
            </div>
        </div>
    </div>

    <div class="row mb-5">
        <div class="col-lg-8 mx-auto">
            <div class="calc-card">
                <h3 class="font-weight-800 mb-4 text-center text-dark" style="font-weight: 800;">Avantajlar & Bilgilendirme</h3>
                <ul class="list-unstyled">
                    <li class="mb-3 d-flex align-items-center">
                        <span class="mr-3" style="font-size: 20px; color: #10b981;">✓</span>
                        <span class="text-muted"><strong>Kart Limitiniz Etkilenmez:</strong> Kredi kartı limitiniz bloke edilmez.</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <span class="mr-3" style="font-size: 20px; color: #10b981;">✓</span>
                        <span class="text-muted"><strong>Esnek Taksit Seçenekleri:</strong> 3 aydan 36 aya kadar vade imkanları sunulur.</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <span class="mr-3" style="font-size: 20px; color: #10b981;">✓</span>
                        <span class="text-muted"><strong>Anında Sonuç:</strong> Islak imza ve evrak kalabalığı olmadan anında onay alınır.</span>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>
