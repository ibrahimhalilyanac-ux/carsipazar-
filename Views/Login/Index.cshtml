@model CreateLoginDto
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "~/Views/UILayout/_UILayout.cshtml";
}

<!-- Google Fonts Import for Premium Typography -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">

<div class="login-container-wrapper">
    <div class="login-card-wrapper shadow-lg">
        
        <!-- Left Panel: Gradient Information Section -->
        <div class="login-left-panel">
            <div class="logo-area">
                <span class="logo-carsi">Çarşı</span><span class="logo-pazar">Pazar</span>
            </div>
            
            <div class="hero-content">
                <h2 class="hero-title">Geleceğin Alışveriş Deneyimi</h2>
                <p class="hero-text">
                    ÇarşıPazar e-ticaret dünyasına oturum açarak indirimli ürünlere, size özel fırsatlara ve sepetinize kaldığınız yerden hızlıca erişin.
                </p>
            </div>
            
            <div class="register-promo">
                <p class="promo-text">Bir hesabınız yok mu? Hemen ücretsiz kayıt olun.</p>
                <a href="/Register/Index/" class="btn-register-link">
                    Kayıt Ol <i class="fas fa-arrow-right ml-2" style="font-size: 13px;"></i>
                </a>
            </div>
        </div>
        
        <!-- Right Panel: Dark Login Form Section -->
        <div class="login-right-panel">
            <h3 class="form-title">Oturum Aç</h3>
            <p class="form-subtitle">Alışveriş işlemlerinize devam edebilmek için lütfen bilgilerinizi giriniz.</p>
            
            <!-- Validation Errors -->
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger border-0 p-3 mb-4 d-flex align-items-start gap-2" style="background-color: rgba(239, 68, 68, 0.1); color: #f87171; border-radius: 12px; font-size: 13px; border-left: 4px solid #ef4444;">
                    <i class="fas fa-exclamation-triangle mt-1 mr-2" style="font-size: 14px; color: #ef4444;"></i>
                    <div class="flex-grow-1">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <span class="d-block">@error.ErrorMessage</span>
                            }
                        }
                    </div>
                </div>
            }
            
            <form method="post" class="login-form">
                <!-- Username Input -->
                <div class="form-group mb-3 position-relative">
                    <label asp-for="Username" class="form-label">Kullanıcı Adınız</label>
                    <div class="input-wrapper">
                        <i class="far fa-user input-icon"></i>
                        <input type="text" asp-for="Username" class="dark-input" required autocomplete="username" placeholder="alice">
                    </div>
                </div>
                
                <!-- Password Input -->
                <div class="form-group mb-4 position-relative">
                    <label asp-for="Password" class="form-label">Şifreniz</label>
                    <div class="input-wrapper">
                        <i class="fas fa-lock input-icon"></i>
                        <input type="password" asp-for="Password" id="password" class="dark-input" required autocomplete="current-password" placeholder="••••••••">
                        <span class="password-toggle-btn" onclick="togglePasswordVisibility()">
                            <i class="far fa-eye" id="togglePasswordIcon"></i>
                        </span>
                    </div>
                </div>
                
                <!-- Submit Button -->
                <button type="submit" class="btn-login-submit">
                    <i class="fas fa-sign-in-alt mr-2"></i> Giriş Yap
                </button>
            </form>
        </div>
    </div>
</div>

<!-- Custom Premium Stylesheets -->
<style>
    .login-container-wrapper {
        font-family: 'Inter', sans-serif;
        background-color: #f8fafc;
        min-height: 80vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 60px 15px;
    }
    
    .login-card-wrapper {
        display: flex;
        width: 100%;
        max-width: 980px;
        background-color: #111625;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.05);
        transition: all 0.3s ease;
    }

    /* Left Panel: Vibrant Indigo & Purple Gradient */
    .login-left-panel {
        width: 50%;
        background: linear-gradient(135deg, #6236ff 0%, #7e3af2 50%, #9042f4 100%);
        padding: 60px 48px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        color: #ffffff;
        position: relative;
        overflow: hidden;
    }
    
    /* Decorative design blobs inside left gradient panel for visual quality */
    .login-left-panel::before {
        content: "";
        position: absolute;
        width: 350px;
        height: 350px;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
        top: -120px;
        left: -120px;
        pointer-events: none;
    }
    
    .login-left-panel::after {
        content: "";
        position: absolute;
        width: 450px;
        height: 450px;
        background: radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, rgba(255, 255, 255, 0) 70%);
        bottom: -180px;
        right: -120px;
        pointer-events: none;
    }

    .logo-area {
        font-family: 'Outfit', sans-serif;
        font-size: 36px;
        font-weight: 800;
        letter-spacing: -0.5px;
        margin-bottom: 60px;
        z-index: 2;
    }
    
    .logo-carsi {
        color: #ffffff;
    }
    
    .logo-pazar {
        color: #ffc72c; /* Bright golden yellow */
    }

    .hero-content {
        margin-bottom: 60px;
        z-index: 2;
    }

    .hero-title {
        font-family: 'Outfit', sans-serif;
        font-size: 40px;
        font-weight: 700;
        line-height: 1.25;
        margin-bottom: 20px;
        color: #ffffff;
        letter-spacing: -0.5px;
    }

    .hero-text {
        font-size: 15px;
        line-height: 1.6;
        color: rgba(255, 255, 255, 0.85);
        font-weight: 400;
    }

    .register-promo {
        z-index: 2;
        margin-top: auto;
    }

    .promo-text {
        font-size: 14.5px;
        color: rgba(255, 255, 255, 0.8);
        margin-bottom: 16px;
    }

    .btn-register-link {
        display: inline-flex;
        align-items: center;
        background-color: transparent;
        color: #ffffff;
        font-size: 14px;
        font-weight: 600;
        padding: 12px 28px;
        border: 1.5px solid rgba(255, 255, 255, 0.4);
        border-radius: 12px;
        text-decoration: none;
        transition: all 0.25s ease;
    }

    .btn-register-link:hover {
        background-color: rgba(255, 255, 255, 0.15);
        border-color: #ffffff;
        color: #ffffff;
        transform: translateX(4px);
        text-decoration: none;
    }

    /* Right Panel: Premium Dark Navy form container */
    .login-right-panel {
        width: 50%;
        background-color: #111625;
        padding: 60px 48px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        color: #ffffff;
    }

    .form-title {
        font-family: 'Outfit', sans-serif;
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 12px;
        color: #ffffff;
    }

    .form-subtitle {
        font-size: 14px;
        color: #94a3b8;
        line-height: 1.5;
        margin-bottom: 36px;
    }

    .form-label {
        font-size: 13.5px;
        font-weight: 500;
        color: #94a3b8;
        margin-bottom: 8px;
        display: block;
    }

    .input-wrapper {
        position: relative;
        display: flex;
        align-items: center;
        margin-bottom: 24px;
    }

    .input-icon {
        position: absolute;
        left: 16px;
        color: #64748b;
        font-size: 16px;
        transition: color 0.2s ease;
    }

    .dark-input {
        width: 100%;
        height: 52px;
        background-color: #161b2c;
        border: 1.5px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 0 16px 0 46px;
        color: #ffffff;
        font-size: 14.5px;
        transition: all 0.25s ease;
        outline: none;
    }

    .dark-input:focus {
        border-color: #6366f1;
        box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.15);
        background-color: #1a2033;
    }
    
    .dark-input:focus + .input-icon {
        color: #6366f1;
    }

    .password-toggle-btn {
        position: absolute;
        right: 16px;
        color: #64748b;
        cursor: pointer;
        padding: 4px;
        font-size: 16px;
        transition: color 0.2s ease;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .password-toggle-btn:hover {
        color: #ffffff;
    }

    .btn-login-submit {
        width: 100%;
        height: 52px;
        background: linear-gradient(135deg, #4f46e5 0%, #6366f1 100%);
        color: #ffffff;
        font-size: 15.5px;
        font-weight: 600;
        border: none;
        border-radius: 12px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 10px 15px -3px rgba(79, 70, 229, 0.3);
        transition: all 0.25s ease;
        margin-top: 10px;
    }

    .btn-login-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 15px 25px -5px rgba(79, 70, 229, 0.4);
        background: linear-gradient(135deg, #4338ca 0%, #4f46e5 100%);
    }

    .btn-login-submit:active {
        transform: translateY(0);
    }

    /* Responsive Grid layout overrides */
    @@media (max-width: 991px) {
        .login-card-wrapper {
            max-width: 720px;
        }
        .hero-title {
            font-size: 32px;
        }
        .logo-area {
            margin-bottom: 40px;
        }
    }

    @@media (max-width: 768px) {
        .login-container-wrapper {
            padding: 40px 15px;
        }
        .login-card-wrapper {
            flex-direction: column;
            max-width: 480px;
            border-radius: 20px;
        }
        .login-left-panel {
            width: 100%;
            padding: 40px 32px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        .login-right-panel {
            width: 100%;
            padding: 40px 32px;
        }
        .hero-content {
            margin-bottom: 40px;
        }
        .hero-title {
            font-size: 28px;
        }
    }
</style>

<!-- Password visibility toggle script -->
<script>
    function togglePasswordVisibility() {
        var passwordInput = document.getElementById("password");
        var toggleIcon = document.getElementById("togglePasswordIcon");
        if (passwordInput.type === "password") {
            passwordInput.type = "text";
            toggleIcon.classList.remove("fa-eye");
            toggleIcon.classList.add("fa-eye-slash");
        } else {
            passwordInput.type = "password";
            toggleIcon.classList.remove("fa-eye-slash");
            toggleIcon.classList.add("fa-eye");
        }
    }
</script>