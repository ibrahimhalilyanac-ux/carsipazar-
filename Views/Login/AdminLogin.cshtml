@model MultiShop.DtoLayer.IdentityDtos.LoginDtos.SignInDto
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8">
    <title>ÇarşıPazar - Admin Giriş Paneli</title>
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1">
    
    <!-- Google Fonts & FontAwesome -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        :root {
            --primary: #f27a1a; /* Trendyol Orange */
            --primary-hover: #d96811;
            --accent: #202442;
            --bg-dark: #090b11;
            --card-bg: rgba(20, 24, 40, 0.75);
            --text-main: #f8fafc;
            --text-muted: #94a3b8;
            --border: rgba(242, 122, 26, 0.15);
            --input-bg: rgba(255, 255, 255, 0.03);
            --input-focus-bg: rgba(255, 255, 255, 0.06);
            --shadow-glow: rgba(242, 122, 26, 0.2);
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: 'Outfit', sans-serif;
            transition: all 0.2s ease;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow-x: hidden;
            position: relative;
        }

        /* Ambient Light Glows */
        .bg-glow-1 {
            position: absolute;
            top: -10%;
            left: -10%;
            width: 50vw;
            height: 50vw;
            background: radial-gradient(circle, rgba(242, 122, 26, 0.12) 0%, rgba(0, 0, 0, 0) 70%);
            border-radius: 50%;
            filter: blur(80px);
            z-index: 1;
        }

        .bg-glow-2 {
            position: absolute;
            bottom: -10%;
            right: -10%;
            width: 50vw;
            height: 50vw;
            background: radial-gradient(circle, rgba(79, 70, 229, 0.08) 0%, rgba(0, 0, 0, 0) 70%);
            border-radius: 50%;
            filter: blur(80px);
            z-index: 1;
        }

        .container {
            width: 100%;
            max-width: 480px;
            padding: 20px;
            z-index: 10;
        }

        .admin-card {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 40px;
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.6), 0 0 40px rgba(242, 122, 26, 0.05);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            text-align: center;
        }

        .admin-logo h1 {
            font-size: 32px;
            font-weight: 900;
            color: #fff;
            letter-spacing: -1px;
            margin-bottom: 5px;
        }

        .admin-logo h1 span {
            color: var(--primary);
        }

        .admin-badge {
            display: inline-block;
            background: rgba(242, 122, 26, 0.1);
            border: 1px solid rgba(242, 122, 26, 0.3);
            color: var(--primary);
            font-size: 11px;
            font-weight: 700;
            padding: 4px 12px;
            border-radius: 20px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            margin-bottom: 25px;
        }

        .form-subtitle {
            font-size: 14px;
            color: var(--text-muted);
            margin-bottom: 30px;
        }

        /* Alert Styling */
        .alert-banner {
            background: rgba(239, 68, 68, 0.08);
            border: 1px solid rgba(239, 68, 68, 0.2);
            border-radius: 12px;
            padding: 12px 16px;
            margin-bottom: 25px;
            color: #fca5a5;
            font-size: 13px;
            text-align: left;
            display: flex;
            gap: 10px;
            align-items: center;
        }

        /* Input Group */
        .input-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 20px;
            text-align: left;
        }

        .input-group label {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
        }

        .input-wrapper {
            position: relative;
        }

        .input-wrapper input {
            width: 100%;
            padding: 14px 16px 14px 45px;
            background: var(--input-bg);
            border: 1.5px solid rgba(255, 255, 255, 0.08);
            border-radius: 12px;
            color: var(--text-main);
            font-size: 14px;
            outline: none;
        }

        .input-wrapper input:focus {
            border-color: var(--primary);
            background: var(--input-focus-bg);
            box-shadow: 0 0 15px var(--shadow-glow);
        }

        .input-icon {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            font-size: 16px;
        }

        .input-wrapper input:focus ~ .input-icon {
            color: var(--primary);
        }

        /* Password eye icon */
        .toggle-password {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--text-muted);
            cursor: pointer;
        }

        .toggle-password:hover {
            color: var(--text-main);
        }

        /* Sign In Button */
        .btn-login {
            width: 100%;
            background: linear-gradient(135deg, var(--primary) 0%, #ff8c3a 100%);
            border: none;
            color: #fff;
            padding: 14px;
            border-radius: 12px;
            font-weight: 700;
            font-size: 15px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(242, 122, 26, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-top: 15px;
        }

        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(242, 122, 26, 0.4);
        }

        /* Quick Login section */
        .quick-login-section {
            margin-top: 30px;
            border-top: 1px solid rgba(255, 255, 255, 0.08);
            padding-top: 20px;
            text-align: left;
        }

        .quick-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--primary);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .quick-users {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .quick-user-btn {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 8px;
            padding: 10px 12px;
            color: var(--text-main);
            font-size: 13px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            cursor: pointer;
            width: 100%;
        }

        .quick-user-btn:hover {
            background: rgba(242, 122, 26, 0.05);
            border-color: rgba(242, 122, 26, 0.3);
        }

        .quick-role {
            font-size: 11px;
            background: rgba(255, 255, 255, 0.08);
            padding: 2px 8px;
            border-radius: 4px;
            color: var(--text-muted);
        }

        .quick-user-btn:hover .quick-role {
            background: rgba(242, 122, 26, 0.2);
            color: var(--primary);
        }

        .back-to-site {
            margin-top: 25px;
            font-size: 13px;
        }

        .back-to-site a {
            color: var(--text-muted);
            text-decoration: none;
        }

        .back-to-site a:hover {
            color: var(--primary);
        }
    </style>
</head>
<body>
    <div class="bg-glow-1"></div>
    <div class="bg-glow-2"></div>

    <div class="container">
        <div class="admin-card">
            <div class="admin-logo">
                <h1>Çarşı<span>Pazar</span></h1>
            </div>
            <div class="admin-badge">Yönetim Konsolu</div>
            
            <p class="form-subtitle">Yönetici paneline erişmek için yetkili bilgilerinizi giriniz.</p>

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert-banner">
                    <i class="fas fa-exclamation-circle" style="color: #ef4444; font-size: 16px;"></i>
                    <div>
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <span>@error.ErrorMessage</span>
                            }
                        }
                    </div>
                </div>
            }

            <form method="post" action="/Admin/Login">
                <div class="input-group">
                    <label>Kullanıcı Adı</label>
                    <div class="input-wrapper">
                        <span class="input-icon"><i class="far fa-user"></i></span>
                        <input type="text" name="Username" id="adminUsername" required placeholder="Yönetici kullanıcı adı">
                    </div>
                </div>

                <div class="input-group">
                    <label>Şifre</label>
                    <div class="input-wrapper">
                        <span class="input-icon"><i class="fas fa-lock"></i></span>
                        <input type="password" name="Password" id="adminPassword" required placeholder="Şifreniz">
                        <span class="toggle-password" onclick="togglePassword()"><i class="far fa-eye" id="eyeIcon"></i></span>
                    </div>
                </div>

                <button type="submit" class="btn-login">
                    <i class="fas fa-shield-alt"></i> Güvenli Giriş Yap
                </button>
            </form>

            <!-- Quick Login Section -->
            <div class="quick-login-section">
                <div class="quick-title">
                    <i class="fas fa-bolt"></i> Hızlı Yönetici Girişi
                </div>
                <div class="quick-users">
                    <button class="quick-user-btn" onclick="fillCredentials('ali01', '1111aA*')">
                        <span><strong>ali01</strong> (ali01 ---- 1111aA*)</span>
                        <span class="quick-role">Admin</span>
                    </button>
                    <button class="quick-user-btn" onclick="fillCredentials('mehmet03', '3333aA*')">
                        <span><strong>mehmet03</strong> (mehmet03 ---- 3333aA*)</span>
                        <span class="quick-role">Yönetici</span>
                    </button>
                </div>
            </div>

            <div class="back-to-site">
                <a href="/"><i class="fas fa-arrow-left"></i> Ana Sayfaya Dön</a>
            </div>
        </div>
    </div>

    <script>
        function togglePassword() {
            var passwordField = document.getElementById("adminPassword");
            var eyeIcon = document.getElementById("eyeIcon");
            if (passwordField.type === "password") {
                passwordField.type = "text";
                eyeIcon.classList.remove("fa-eye");
                eyeIcon.classList.add("fa-eye-slash");
            } else {
                passwordField.type = "password";
                eyeIcon.classList.remove("fa-eye-slash");
                eyeIcon.classList.add("fa-eye");
            }
        }

        function fillCredentials(username, password) {
            document.getElementById("adminUsername").value = username;
            document.getElementById("adminPassword").value = password;
            
            // Subtle flash animation to indicate auto-fill
            const card = document.querySelector(".admin-card");
            card.style.boxShadow = "0 20px 40px rgba(0, 0, 0, 0.6), 0 0 50px rgba(242, 122, 26, 0.3)";
            setTimeout(() => {
                card.style.boxShadow = "0 20px 40px rgba(0, 0, 0, 0.6), 0 0 40px rgba(242, 122, 26, 0.05)";
            }, 500);
        }
    </script>
</body>
</html>
