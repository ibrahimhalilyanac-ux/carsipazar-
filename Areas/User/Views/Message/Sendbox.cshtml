@model List<ResultSendboxMessageDto>
@{
    ViewData["Title"] = "Giden Kutusu";
    Layout = "~/Areas/User/Views/UserLayout/Index.cshtml";
    int count = 0;
}

<div class="d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom">
    <h3 class="font-weight-bold text-dark m-0" style="font-weight: 800; font-size: 24px;">📤 Giden Kutusu</h3>
    <span class="badge badge-pill badge-primary px-3 py-2 text-white" style="font-size: 13px; background-color: #4f46e5;">Toplam @Model.Count Mesaj</span>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="text-center py-5">
        <div style="font-size: 60px;">✉️</div>
        <h5 class="mt-3 font-weight-bold text-muted">Henüz gönderilmiş bir mesajınız bulunmamaktadır.</h5>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle" style="border-collapse: separate; border-spacing: 0 10px;">
            <thead>
                <tr class="text-muted" style="font-size: 13px; font-weight: 700; background-color: #f8fafc;">
                    <th class="border-0 px-4 py-3" style="border-radius: 12px 0 0 12px;">#</th>
                    <th class="border-0 px-4 py-3">Alıcı</th>
                    <th class="border-0 px-4 py-3">Konu</th>
                    <th class="border-0 px-4 py-3">Tarih</th>
                    <th class="border-0 px-4 py-3">Durum</th>
                    <th class="border-0 px-4 py-3 text-right" style="border-radius: 0 12px 12px 0;">İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    count++;
                    <tr class="shadow-sm" style="background-color: #fff; transition: transform 0.2s;">
                        <td class="px-4 py-3 font-weight-bold align-middle" style="border-radius: 12px 0 0 12px; border: 1px solid #e2e8f0; border-right: 0;">#@count</td>
                        <td class="px-4 py-3 align-middle font-weight-bold text-dark" style="border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0;">@item.SenderId</td>
                        <td class="px-4 py-3 align-middle" style="border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0;">@item.Subject</td>
                        <td class="px-4 py-3 align-middle text-muted" style="border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0;">
                            @(((DateTime)item.MessageDate).ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")))
                        </td>
                        <td class="px-4 py-3 align-middle" style="border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0;">
                            @if (item.IsRead)
                            {
                                <span class="badge badge-pill px-2 py-1" style="background-color: #f1f5f9; color: #64748b; font-size: 11px; font-weight: 700;">Okundu</span>
                            }
                            else
                            {
                                <span class="badge badge-pill px-2 py-1" style="background-color: #fef3c7; color: #d97706; font-size: 11px; font-weight: 700;">İletildi</span>
                            }
                        </td>
                        <td class="px-4 py-3 align-middle text-right" style="border-radius: 0 12px 12px 0; border: 1px solid #e2e8f0; border-left: 0;">
                            <a href="#" class="btn btn-sm btn-info px-3 py-2 font-weight-bold text-white mr-1" style="border-radius: 8px; font-size: 12px; background-color: #0284c7; border-color: #0284c7;">
                                Oku
                            </a>
                            <a href="#" class="btn btn-sm btn-danger px-3 py-2 font-weight-bold text-white" style="border-radius: 8px; font-size: 12px; background-color: #ef4444; border-color: #ef4444;">
                                Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<style>
    .table tbody tr {
        transition: all 0.2s ease;
    }
    .table tbody tr:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.05) !important;
    }
</style>
