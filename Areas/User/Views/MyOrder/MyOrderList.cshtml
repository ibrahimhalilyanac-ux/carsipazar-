@model List<ResultOrderingByUserIdDto>
@{
    ViewData["Title"] = "Sipariş Geçmişim";
    Layout = "~/Areas/User/Views/UserLayout/Index.cshtml";
    int count = 0;
}

<div class="d-flex align-items-center justify-content-between mb-4 pb-2 border-bottom">
    <h3 class="font-weight-bold text-dark m-0" style="font-weight: 800; font-size: 24px;">📦 Sipariş Geçmişim</h3>
    <span class="badge badge-pill badge-info px-3 py-2 text-white" style="font-size: 13px; background-color: #4f46e5;">Toplam @Model.Count Sipariş</span>
</div>

@if (Model == null || Model.Count == 0)
{
    <div class="text-center py-5">
        <div style="font-size: 60px;">🛒</div>
        <h5 class="mt-3 font-weight-bold text-muted">Henüz hiç siparişiniz bulunmamaktadır.</h5>
        <a href="/" class="btn btn-primary mt-3 px-4 py-2" style="border-radius: 8px; font-weight: 700; background-color: #4f46e5; border-color: #4f46e5;">Alışverişe Başla</a>
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle" style="border-collapse: separate; border-spacing: 0 10px;">
            <thead>
                <tr class="text-muted" style="font-size: 13px; font-weight: 700; background-color: #f8fafc;">
                    <th class="border-0 px-4 py-3" style="border-radius: 12px 0 0 12px;">#</th>
                    <th class="border-0 px-4 py-3">Toplam Fiyat</th>
                    <th class="border-0 px-4 py-3">Sipariş Tarihi</th>
                    <th class="border-0 px-4 py-3 text-right" style="border-radius: 0 12px 12px 0;">Detaylar</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    count++;
                    <tr class="shadow-sm border-0" style="background-color: #fff; transition: transform 0.2s;">
                        <td class="px-4 py-3 font-weight-bold align-middle" style="border-radius: 12px 0 0 12px; border: 1px solid #e2e8f0; border-right: 0;">#@count</td>
                        <td class="px-4 py-3 align-middle font-weight-bold" style="border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0; font-size: 15px; color: #4f46e5;">
                            @item.TotalPrice.ToString("C2", new System.Globalization.CultureInfo("tr-TR"))
                        </td>
                        <td class="px-4 py-3 align-middle text-muted" style="border-top: 1px solid #e2e8f0; border-bottom: 1px solid #e2e8f0;">
                            @(((DateTime)item.OrderDate).ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR")))
                        </td>
                        <td class="px-4 py-3 align-middle text-right" style="border-radius: 0 12px 12px 0; border: 1px solid #e2e8f0; border-left: 0;">
                            <button onclick="showOrderDetail(@item.OrderingId)" class="btn btn-sm btn-outline-primary px-3 py-2 font-weight-bold" style="border-radius: 8px; font-size: 12px; border-color: #4f46e5; color: #4f46e5; background: transparent; cursor: pointer; transition: all 0.2s;">
                                Sipariş Detayı <i class="fas fa-arrow-right ml-1"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<!-- Order Detail Modal -->
<div class="modal fade" id="orderDetailModal" tabindex="-1" aria-labelledby="orderDetailModalLabel" aria-hidden="true" style="border-radius: 16px;">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content" style="border-radius: 16px; border: none; box-shadow: 0 10px 30px rgba(0,0,0,0.15);">
            <div class="modal-header bg-light py-3" style="border-top-left-radius: 16px; border-top-right-radius: 16px; border-bottom: 1px solid #e2e8f0;">
                <h5 class="modal-title font-weight-bold text-dark m-0" id="orderDetailModalLabel" style="font-weight: 800; font-size: 18px;">🔍 Sipariş Detayları</h5>
                <button type="button" class="close" data-dismiss="modal" aria-label="Close" style="outline: none;">
                    <span aria-hidden="true" style="font-size: 24px;">&times;</span>
                </button>
            </div>
            <div class="modal-body p-4" id="orderDetailModalBody">
                <!-- Dynamic Content Loads Here -->
                <div class="text-center py-4">
                    <div class="spinner-border text-primary" role="status" style="color: #4f46e5 !important;">
                        <span class="sr-only">Yükleniyor...</span>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-radius: 16px; border-top: 1px solid #e2e8f0;">
                <button type="button" class="btn btn-secondary font-weight-bold px-4 py-2" data-dismiss="modal" style="border-radius: 8px; background-color: #64748b; border-color: #64748b;">Kapat</button>
            </div>
        </div>
    </div>
</div>

<style>
    .table tbody tr {
        transition: all 0.2s ease;
    }
    .table tbody tr:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px rgba(0,0,0,0.05) !important;
    }
    .btn-outline-primary:hover {
        background-color: #4f46e5 !important;
        border-color: #4f46e5 !important;
        color: #fff !important;
    }
</style>

<script>
    function showOrderDetail(orderingId) {
        // Set loading spinner first
        document.getElementById('orderDetailModalBody').innerHTML = `
            <div class="text-center py-5">
                <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem; color: #4f46e5 !important;">
                    <span class="sr-only">Yükleniyor...</span>
                </div>
                <p class="mt-2 text-muted font-weight-bold">Sipariş detayları yükleniyor...</p>
            </div>
        `;
        
        // Show modal (Trigger Bootstrap modal through jQuery since it is loaded in UILayout)
        $('#orderDetailModal').modal('show');
        
        // Fetch content via AJAX
        $.get('/User/MyOrder/GetOrderDetails?id=' + orderingId, function(data) {
            $('#orderDetailModalBody').html(data);
        }).fail(function() {
            $('#orderDetailModalBody').html(`
                <div class="alert alert-danger font-weight-bold text-center" role="alert" style="border-radius: 12px;">
                    ⚠️ Sipariş detayları yüklenirken bir hata oluştu. Lütfen tekrar deneyin.
                </div>
            `);
        });
    }
</script>