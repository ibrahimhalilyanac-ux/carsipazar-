@{
    Layout = "~/Views/UILayout/_UILayout.cshtml";
    var currentUrl = ViewContext.HttpContext.Request.Path.ToString().ToLower();
}

<div class="container-fluid py-5" style="background-color: #f8fafc;">
    <div class="row px-xl-5">
        <!-- Sidebar Navigation (col-lg-3) -->
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="profile-sidebar shadow-sm p-4 bg-white" style="border-radius: 16px; border: 1px solid #e2e8f0;">
                <div class="text-center mb-4 pb-3 border-bottom">
                    <div class="d-inline-flex align-items-center justify-content-center bg-primary text-white rounded-circle font-weight-bold" style="width: 60px; height: 60px; font-size: 24px;">
                        👤
                    </div>
                    <h5 class="mt-3 mb-1 font-weight-bold text-dark">Ali Yıldırım</h5>
                    <span class="badge badge-pill badge-primary">Müşteri Paneli</span>
                </div>
                
                <ul class="nav flex-column sidebar-nav-list" style="list-style: none; padding: 0; margin: 0;">
                    <li class="nav-item mb-2">
                        <a href="/User/MyOrder/MyOrderList/" class="nav-link d-flex align-items-center text-dark p-3 @(currentUrl.Contains("myorderlist") ? "active-link" : "")" style="font-weight: 600; border-radius: 12px; gap: 10px; text-decoration: none;">
                            <span style="font-size: 18px;">📦</span> Sipariş Geçmişim
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a href="/User/Message/Inbox/" class="nav-link d-flex align-items-center text-dark p-3 @(currentUrl.Contains("inbox") ? "active-link" : "")" style="font-weight: 600; border-radius: 12px; gap: 10px; text-decoration: none;">
                            <span style="font-size: 18px;">📥</span> Gelen Kutusu
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a href="/User/Message/Sendbox/" class="nav-link d-flex align-items-center text-dark p-3 @(currentUrl.Contains("sendbox") ? "active-link" : "")" style="font-weight: 600; border-radius: 12px; gap: 10px; text-decoration: none;">
                            <span style="font-size: 18px;">📤</span> Giden Kutusu
                        </a>
                    </li>
                    <li class="nav-item mb-2">
                        <a href="/Discount/Index/" class="nav-link d-flex align-items-center text-dark p-3" style="font-weight: 600; border-radius: 12px; gap: 10px; text-decoration: none;">
                            <span style="font-size: 18px;">🎟️</span> İndirim Kuponlarım
                        </a>
                    </li>
                    <li class="nav-item mt-4 pt-3 border-top">
                        <a href="/Login/LogOut/" class="nav-link d-flex align-items-center text-danger p-3" style="font-weight: 600; border-radius: 12px; gap: 10px; text-decoration: none;">
                            <span style="font-size: 18px;">🚪</span> Çıkış Yap
                        </a>
                    </li>
                </ul>
            </div>
        </div>

        <!-- Main Content Panel (col-lg-9) -->
        <div class="col-lg-9 col-md-8">
            <div class="profile-content shadow-sm p-4 bg-white" style="border-radius: 16px; border: 1px solid #e2e8f0; min-height: 500px;">
                @RenderBody()
            </div>
        </div>
    </div>
</div>

<style>
    .sidebar-nav-list .nav-link {
        transition: all 0.2s ease-in-out;
        color: #475569 !important;
    }
    .sidebar-nav-list .nav-link:hover {
        background-color: #f1f5f9;
        color: var(--primary-color) !important;
        transform: translateX(4px);
    }
    
    /* Active state styling */
    .sidebar-nav-list .active-link {
        background-color: #ede9fe !important;
        color: #4f46e5 !important;
        border-left: 4px solid #4f46e5;
    }
</style>